@inherits LayoutComponentBase

<div class="page">
    <header class="site-header border-bottom bg-white">
        <nav class="navbar navbar-expand-sm navbar-light container-xxl">
            <a class="navbar-brand fw-semibold" href="">Three Revert Watch</a>
            <div class="ms-auto d-flex align-items-center gap-3">
                <NavLink class="nav-link px-0" href="" Match="NavLinkMatch.All">Conflicts</NavLink>
                <NavLink class="nav-link px-0" href="pipeline">Pipeline</NavLink>
                <NavLink class="nav-link px-0" href="about">About</NavLink>
            </div>
        </nav>
    </header>

    <main class="page-main">
        <article class="content container-xxl">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
