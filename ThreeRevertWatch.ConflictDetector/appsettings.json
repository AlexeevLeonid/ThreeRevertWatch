{
  "Kafka": {
    "BootstrapServers": "localhost:29092",
    "GroupId": "threerevertwatch-conflictdetector",
    "AutoOffsetReset": "earliest",
    "EnableAutoCommit": false
  },
  "Topics": {
    "RawEdits": "wiki.raw-edits",
    "TopicMatchedEdits": "wiki.topic-matched-edits",
    "ArticleConflictUpdates": "wiki.article-conflict-updates",
    "TopicConflictUpdates": "wiki.topic-conflict-updates"
  },
  "ConnectionStrings": {
    "PostgreSQL": "Host=localhost;Database=threerevertwatch;Username=threerevertwatch"
  },
  "Database": {
    "MigrateOnStartup": true
  },
  "ConflictDetector": {
    "RecentRevisionWindowSize": 50,
    "RecentEditWindowSize": 100,
    "StateSnapshotIntervalSeconds": 30,
    "RevertWindowHours": 6,
    "ThreeRevertWindowHours": 24,
    "DeepDiffEnabled": false
  },
  "Serilog": {
    "MinimumLevel": { "Default": "Information", "Override": { "Microsoft": "Warning" } },
    "WriteTo": [
      { "Name": "Console" },
      { "Name": "Seq", "Args": { "serverUrl": "http://localhost:5341" } }
    ]
  }
}
