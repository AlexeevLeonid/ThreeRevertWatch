{
  "Kafka": {
    "BootstrapServers": "localhost:29092",
    "GroupId": "threerevertwatch-topicmatcher",
    "AutoOffsetReset": "earliest",
    "EnableAutoCommit": false
  },
  "Topics": {
    "RawEdits": "wiki.raw-edits",
    "TopicMatchedEdits": "wiki.topic-matched-edits",
    "ArticleConflictUpdates": "wiki.article-conflict-updates",
    "TopicConflictUpdates": "wiki.topic-conflict-updates"
  },
  "ConnectionStrings": {
    "PostgreSQL": "Host=localhost;Database=threerevertwatch;Username=threerevertwatch"
  },
  "Database": {
    "MigrateOnStartup": true
  },
  "ConflictTopics": {
    "CandidateThreshold": 0.25,
    "ConfirmedThreshold": 0.70,
    "DetectorPublishThreshold": 0.50,
    "Topics": [
      {
        "Id": "russo_ukrainian_war",
        "DisplayName": "Российско-украинская война",
        "Wiki": "ruwiki",
        "IsActive": true,
        "SeedPageIds": [],
        "SeedTitles": [ "Российско-украинская война", "Вторжение России на Украину" ],
        "TitleKeywords": [ "Украина", "Россия", "Донбасс", "Крым" ],
        "ExcludeTitleKeywords": [ "фильм", "песня" ]
      },
      {
        "Id": "israeli_palestinian_conflict",
        "DisplayName": "Израильско-палестинский конфликт",
        "Wiki": "ruwiki",
        "IsActive": true,
        "SeedPageIds": [],
        "SeedTitles": [ "Израильско-палестинский конфликт", "Война Израиля с ХАМАС" ],
        "TitleKeywords": [ "Израиль", "Палестина", "Газа", "ХАМАС" ],
        "ExcludeTitleKeywords": [ "фильм", "песня" ]
      },
      {
        "Id": "elections",
        "DisplayName": "Выборы",
        "Wiki": "ruwiki",
        "IsActive": true,
        "SeedPageIds": [],
        "SeedTitles": [ "Выборы" ],
        "TitleKeywords": [ "выборы", "президентские выборы", "парламентские выборы" ],
        "ExcludeTitleKeywords": [ "фильм", "альбом" ]
      },
      {
        "Id": "migration_crisis",
        "DisplayName": "Миграционный кризис",
        "Wiki": "ruwiki",
        "IsActive": true,
        "SeedPageIds": [],
        "SeedTitles": [ "Миграционный кризис" ],
        "TitleKeywords": [ "миграционный кризис", "мигранты", "беженцы" ],
        "ExcludeTitleKeywords": [ "фильм", "роман" ]
      }
    ]
  },
  "Serilog": {
    "MinimumLevel": { "Default": "Information", "Override": { "Microsoft": "Warning" } },
    "WriteTo": [
      { "Name": "Console" },
      { "Name": "Seq", "Args": { "serverUrl": "http://localhost:5341" } }
    ]
  }
}
